# --- Telegram ---
BOT_TOKEN=123456:changeme
ADMIN_ID=0                 # tg id главного админа (супер-админ)

# Супергруппа с форум-топиками для тендеров/модерации
GROUP_ID=0                # id супергруппы (со знаком -100...)
MODERATION_THREAD_ID=0    # topic для карточек модерации (заявки исполнителей, новые биты)

# Топики категорий-тендеров (в той же супергруппе GROUP_ID)
CUSTOM_BEATS_THREAD_ID=0
MIXING_THREAD_ID=0
GHOSTWRITING_THREAD_ID=0
VISUAL_THREAD_ID=0
VIDEOGRAPHER_THREAD_ID=0
EDITING_THREAD_ID=0
PHOTO_THREAD_ID=0

# Реквизиты для оплаты (клиенту показывается как есть)
PAYMENT_DETAILS=Карта 0000 0000 0000 0000 (Банк, Получатель)

# Публичный канал-зеркало отзывов
REVIEWS_CHANNEL_ID=0      # id канала (-100...)
REVIEWS_CHANNEL_URL=https://t.me/your_reviews_channel

# Прокси до Telegram API (если api.telegram.org блокируется провайдером).
# socks5://user:pass@host:port  или  http://host:port. Пусто = напрямую.
TELEGRAM_PROXY=

# Дебаг настройки: 1 = бот отвечает chat.id/thread_id на сообщения в группах.
# Включи на время сбора id топиков, потом верни 0.
DEBUG_IDS=0

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=screw
POSTGRES_USER=screw
POSTGRES_PASSWORD=screw

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
