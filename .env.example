# === СЕКРЕТЫ И ИНФРАСТРУКТУРА (не коммитятся) ===
# Стабильные не-секретные id (админ, группа, топики, канал, реквизиты)
# лежат в bot/app_config.py и bot/categories.py, а НЕ здесь.

# --- Telegram (секрет) ---
BOT_TOKEN=123456:changeme

# --- Прокси до Telegram API (если api.telegram.org блокируется) ---
# socks5://user:pass@host:port  или  http://host:port. Пусто = напрямую.
TELEGRAM_PROXY=

# --- Дебаг: бот отвечает chat.id/thread_id на сообщения в группах ---
# Включи на время сбора id топиков, потом верни 0.
DEBUG_IDS=0

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=screw
POSTGRES_USER=screw
POSTGRES_PASSWORD=screw

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
